# Murray Context Ledger — required configuration.
# Copy to .env and fill in. The app fails fast at startup if anything is missing.

# --- Auth0 (identity provider) -----------------------------------------------
# Tenant domain, no scheme/trailing slash, e.g. murray.us.auth0.com
AUTH0_DOMAIN=your-tenant.us.auth0.com
# The `aud` claim we accept. Clients send the Auth0 ID token (see docs/AUTH.md),
# so this is the Auth0 application's client ID.
AUTH0_AUDIENCE=your-auth0-application-client-id
# The Auth0 API identifier for the ledger; the audience MCP access tokens carry
# (docs/CONNECT.md Part 1). Also set it as the tenant's Default Audience.
AUTH0_API_AUDIENCE=https://ledger.yourdomain.com/mcp

# --- MCP -----------------------------------------------------------------------
# Canonical public URL of the MCP endpoint (RFC 9728 `resource`). For tunnel
# testing set it to https://<tunnel-host>/mcp and restart the server.
RESOURCE_SERVER_URL=http://127.0.0.1:8080/mcp

# --- Supabase -----------------------------------------------------------------
# Local stack default shown; replace with your project URL for hosted envs.
SUPABASE_URL=http://127.0.0.1:54321
# Anon (publishable) key — request-path access, RLS enforced.
SUPABASE_ANON_KEY=your-anon-key
# Service-role key — BYPASSES RLS. Pipeline jobs only; never the request path,
# never shipped to clients.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HS256 secret the Supabase stack validates Data-API JWTs with. The MCP layer
# mints short-lived per-user DB tokens with it (docs/AUTH.md); tests mint user
# JWTs with it. `supabase start` default shown (public knowledge, local-only);
# for hosted projects use the project's legacy JWT secret.
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
